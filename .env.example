# ─────────────────────────────────────────────────────────────────
#  .env.example — safe template, commit this to GitHub
#  Copy to .env and fill in your real values.
#  NEVER commit .env to GitHub.
# ─────────────────────────────────────────────────────────────────

# ── Sepolia RPC endpoint ───────────────────────────────────────────
# Get a free endpoint from Alchemy: https://dashboard.alchemy.com
# or Infura: https://infura.io
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# ── Deployer wallet private key ────────────────────────────────────
# Export from MetaMask: Account Details → Export Private Key
# Must have Sepolia ETH — get some free at https://sepoliafaucet.com
# Include the 0x prefix.
PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY

# ── GitHub Actions bot wallet ──────────────────────────────────────
# A SEPARATE wallet used only by GitHub Actions to send transactions.
# Fund it with a small amount of Sepolia ETH for gas fees.
# Add its private key as a GitHub Actions Secret named BOT_PRIVATE_KEY.
BOT_PRIVATE_KEY=0xYOUR_BOT_WALLET_PRIVATE_KEY

# ── Deployed contract addresses ────────────────────────────────────
# These are populated automatically by deploy.js after deployment.
# Copy the printed addresses here and also add them as GitHub Secrets.
PIPELINE_REGISTRY_ADDRESS=
EVENT_LOGGER_ADDRESS=
VERIFIER_ADDRESS=

# ── Pipeline ID ────────────────────────────────────────────────────
# The pipelineId returned by registerPipeline() in PipelineRegistry.
# Set this after running the registration step in deploy.js.
PIPELINE_ID=1

# ── Etherscan API key (optional) ───────────────────────────────────
# Used to verify and publish contract source code on Etherscan.
# Get a free key at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Gas reporting (optional) ───────────────────────────────────────
# Set to true to print gas costs per function during tests.
# Useful for the performance evaluation section of your dissertation.
REPORT_GAS=false

SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/5rx184x3_Is8RARp0H0Nw
PRIVATE_KEY=0xYOUR_DEPLOYER_WALLET_PRIVATE_KEY
BOT_PRIVATE_KEY=0xYOUR_BOT_WALLET_PRIVATE_KEY
BOT_WALLET_ADDRESS=0xYOUR_BOT_WALLET_PUBLIC_ADDRESS